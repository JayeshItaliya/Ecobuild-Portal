# ============================================================================
# ECOBUILD PORTAL - Environment Configuration
# ============================================================================

# ======================================================
# DJANGO CORE SETTINGS
# ======================================================
SECRET_KEY=
DEBUG=
ALLOWED_HOSTS=

# ======================================================
# DATABASE CONFIGURATION
# ======================================================

DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ======================================================
# GOOGLE CLOUD TRANSLATION API
# ======================================================
# For automatic translation to Hebrew, Russian, and Arabic
# Get credentials from: Google Cloud Console > IAM & Admin > Service Accounts

USE_GOOGLE_TRANSLATE=false
GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json

# Alternative (not recommended - less secure)
# GOOGLE_TRANSLATE_API_KEY=your-api-key
# GOOGLE_CLOUD_PROJECT_ID=your-project-id

# ======================================================
# FILE STORAGE CONFIGURATION
# ======================================================
# Set to 'false' for local storage (development)
# Set to 'true' for AWS S3 storage (production)

USE_S3_STORAGE=

# ======================================================
# AWS S3 CONFIGURATION (Production File Storage)
# ======================================================
# Required only if USE_S3_STORAGE=true
# Create bucket and IAM user at: AWS Console > S3 & IAM

AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=ap-south-1

# ======================================================
# OAUTH AUTHENTICATION (Google & Facebook)
# ======================================================
# For social login features

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ======================================================
# CORS & CSRF CONFIGURATION
# ======================================================
# URLs that can access your API (production)

# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ======================================================
# APPLICATION URLS
# ======================================================
DOMAIN_URL=http://localhost:8000
FRONTEND_DOMAIN=http://localhost:3000
